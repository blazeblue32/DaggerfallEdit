+static IReadOnlySet<string> GetLooseContentSemanticFieldPaths()
+{
+    return new HashSet<string>(StringComparer.OrdinalIgnoreCase)
+    {
+        "replacement",
+        "portrait",
+        "ruleContext"
+    };
+}
