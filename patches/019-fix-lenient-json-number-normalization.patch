+static bool IsLooseJsonNumberTokenStart(string text, int index)
+{
+    for (int i = index - 1; i >= 0; i--)
+    {
+        char c = text[i];
+
+        if (char.IsWhiteSpace(c))
+            continue;
+
+        return c == '[' || c == '{' || c == ',' || c == ':';
+    }
+
+    return true;
+}
